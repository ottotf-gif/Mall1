import { kund } from '../config/kund';

/**
 * Sätter kundens färger som CSS-variabler på <html>.
 *
 * Poängen: Tailwind-klasserna (bg-accent, text-jour, ...) läser
 * variablerna, så du behöver aldrig röra tailwind.config.js.
 * Byt hexkod i kund.ts — klart.
 *
 * Genererar också en mörkare hover-variant automatiskt, så du
 * slipper handplocka två färger som passar ihop.
 */

/** '#E8722C' -> '232 114 44' (formatet Tailwind vill ha för /opacity ska funka) */
function tillRgb(hex: string): string {
  const h = hex.replace('#', '').trim();
  const full =
    h.length === 3
      ? h
          .split('')
          .map((c) => c + c)
          .join('')
      : h;

  const r = parseInt(full.slice(0, 2), 16);
  const g = parseInt(full.slice(2, 4), 16);
  const b = parseInt(full.slice(4, 6), 16);

  return `${r} ${g} ${b}`;
}

/** Mörkare variant för hover-läge. procent = hur mycket mörkare, 0–1. */
function morkare(hex: string, procent = 0.14): string {
  const [r, g, b] = tillRgb(hex).split(' ').map(Number);
  const d = (v: number) => Math.max(0, Math.round(v * (1 - procent)));
  return `${d(r)} ${d(g)} ${d(b)}`;
}

export function tillampaTema(): void {
  const rot = document.documentElement;
  const { accent, jour, lage } = kund.tema;

  rot.style.setProperty('--accent', tillRgb(accent));
  rot.style.setProperty('--accent-hover', morkare(accent));
  rot.style.setProperty('--jour', tillRgb(jour));
  rot.style.setProperty('--jour-hover', morkare(jour));

  rot.dataset.lage = lage;
}
